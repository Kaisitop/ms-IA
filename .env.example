# Ruta al clasificador entrenado (copiar manualmente a models/)
MODEL_PATH=./models/my_yamnet_classifier.h5

# YAMNet base (TensorFlow Hub)
YAMNET_HUB_URL=https://tfhub.dev/google/yamnet/1
TFHUB_CACHE_DIR=./.cache/tfhub

# Parámetros de inferencia (mismos que DetectorSonidosAI)
SAMPLE_RATE=16000
BLOCK_SIZE=8000
WINDOW_SIZE=14000
NOISE_GATE=0.015
ALERT_CONFIDENCE_PCT=80.0

# NATS (mismo broker que ms-core)
NATS_SERVERS=nats://localhost:4222
NATS_SUBJECT_AUDIO_READY=eventos.audio.ready

# Ruta raíz del bridge (para leer WAV guardados)
BRIDGE_ROOT=../ms-IoT-Bridge

# HTTP
HTTP_PORT=8200
HTTP_HOST=0.0.0.0
